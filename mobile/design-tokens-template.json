    "text": {
      "primary": {
        "value": "{color.neutral.1000}",
        "type": "color",
        "description": "主要文本颜色，用于标题和重要内容",
        "$extensions": {
          "mode": {
            "light": "rgba(15, 23, 33, 0.9)",
            "dark": "rgba(255, 255, 255, 0.9)"
          }
        }
      },
      "secondary": {
        "value": "{color.neutral.1000}",
        "type": "color",
        "description": "次要文本颜色，用于描述和辅助信息",
        "$extensions": {
          "mode": {
            "light": "rgba(15, 23, 33, 0.6)",
            "dark": "rgba(255, 255, 255, 0.6)"
          }
        }
      },
      "tertiary": {
        "value": "{color.neutral.1000}",
        "type": "color",
        "description": "三级文本颜色，用于提示和不重要信息",
        "$extensions": {
          "mode": {
            "light": "rgba(15, 23, 33, 0.45)",
            "dark": "rgba(255, 255, 255, 0.45)"
          }
        }
      },
